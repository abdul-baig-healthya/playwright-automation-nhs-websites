{
  "name": "pharmacy-e2e-tests",
  "version": "1.0.0",
  "description": "Playwright E2E tests for multiple pharmacy websites. Select a pharmacy via --project or use npm scripts below.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:pharmaease": "playwright test --project=\"Pharmaease\"",
    "test:paydens": "playwright test --project=\"Paydens\"",
    "test:pharmacist": "playwright test --project=\"The Pharmacist\"",
    "test:localhost": "playwright test --project=\"Localhost\"",
    "dashboard": "node dashboard.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.6.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
