{
  "name": "pharmacy-e2e-tests",
  "version": "1.0.0",
  "description": "Standalone Playwright E2E tests for pharmacy apps. Configure BASE_URL to run against any pharmacy instance.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.6.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5"
  }
}
